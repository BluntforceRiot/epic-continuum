{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://epic-continuum.local/schemas/root_bundle_manifest.schema.json",
  "title": "Epic Continuum Root Bundle Manifest",
  "type": "object",
  "required": [
    "schema",
    "bundle_id",
    "created_at",
    "profile",
    "symlink_policy",
    "redaction_profile",
    "file_count",
    "total_size_bytes",
    "files",
    "copy",
    "preflight",
    "manifest_hash"
  ],
  "properties": {
    "schema": {
      "const": "epic_continuum.root_bundle_manifest.v1"
    },
    "bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "profile": {
      "enum": [
        "portable",
        "shareable"
      ]
    },
    "symlink_policy": {
      "enum": [
        "fail",
        "skip"
      ]
    },
    "redaction_profile": {
      "enum": [
        "private",
        "portable",
        "shareable"
      ]
    },
    "root_identity_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "file_count": {
      "type": "integer",
      "minimum": 0
    },
    "total_size_bytes": {
      "type": "integer",
      "minimum": 0
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "sha256",
          "size_bytes",
          "mode"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0
          },
          "mode": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": false
      }
    },
    "copy": {
      "type": "object",
      "required": [
        "copied_files",
        "copied_bytes",
        "skipped_count",
        "skipped",
        "symlink_count",
        "symlinks"
      ],
      "properties": {
        "copied_files": {
          "type": "integer",
          "minimum": 0
        },
        "copied_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "skipped_count": {
          "type": "integer",
          "minimum": 0
        },
        "skipped": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "symlink_count": {
          "type": "integer",
          "minimum": 0
        },
        "symlinks": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      },
      "additionalProperties": false
    },
    "preflight": {
      "type": "object",
      "required": [
        "root_verification_ok",
        "staged_root_verification_ok",
        "secret_audit_complete",
        "secret_finding_count",
        "secret_allowlisted_finding_count",
        "proof_pack_count",
        "proof_packs_ok",
        "artifact_count",
        "artifact_ledger_ok",
        "portable_metadata_files_scanned",
        "portable_metadata_sqlite_values_scanned",
        "portable_metadata_complete",
        "portable_metadata_ok",
        "restore_drill_ran"
      ],
      "properties": {
        "root_verification_ok": {
          "const": true
        },
        "staged_root_verification_ok": {
          "const": true
        },
        "secret_audit_complete": {
          "const": true
        },
        "secret_finding_count": {
          "const": 0
        },
        "secret_allowlisted_finding_count": {
          "type": "integer",
          "minimum": 0
        },
        "proof_pack_count": {
          "type": "integer",
          "minimum": 0
        },
        "proof_packs_ok": {
          "const": true
        },
        "artifact_count": {
          "type": "integer",
          "minimum": 0
        },
        "artifact_ledger_ok": {
          "const": true
        },
        "portable_metadata_files_scanned": {
          "type": "integer",
          "minimum": 0
        },
        "portable_metadata_sqlite_values_scanned": {
          "type": "integer",
          "minimum": 0
        },
        "portable_metadata_complete": {
          "const": true
        },
        "portable_metadata_ok": {
          "const": true
        },
        "restore_drill_ran": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "manifest_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "additionalProperties": false
}
